generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 成员表 ====================
model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String
  role             String   // admin, member
  feishuEmployeeId String?  @unique
  department       String?  // 所属部门，null = 无部门限制（管理员）
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // 关系：一个 User 创建多个 Candidate
  createdCandidates Candidate[] @relation("CreatedCandidates")
  
  // 关系：一个 User 创建多个 Job
  createdJobs       Job[]       @relation("CreatedJobs")
  
  // 关系：一个 User 被分配多个 StageRecord
  assignedStages    StageRecord[] @relation("AssignedStages")
  
  // 关系：一个 User 创建多个 InterviewFeedback
  createdFeedbacks  InterviewFeedback[] @relation("CreatedFeedbacks")

  // 关系：一个 User 创建多个 Interview（面试安排）
  createdInterviews Interview[] @relation("CreatedInterviews")

  // 关系：一个 User 创建多个 CommunicationLog
  createdCommunicationLogs CommunicationLog[] @relation("CreatedCommunicationLogs")

  // 关系：一个 User 接收多条通知
  notifications  Notification[]

  // 关系：一个 User 提交的 HC 申请
  hcRequests  HCRequest[] @relation("HCRequests")

  // 关系：一个 User 审批的 HC 申请
  hcApprovals HCRequest[] @relation("HCApprovals")

  // 关系：一个 User 产生多个操作日志
  operationLogs     OperationLog[] @relation("UserOperationLogs")

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("user")
}

// ==================== 职位表 ====================
model Job {
  id           String   @id @default(cuid())
  title        String
  departments  Json     // JSON 数组，多选部门
  level        String   // 职级
  skills       Json     // JSON 数组，技能要求
  location     String   // 地域
  type         String   // 社招/校招/实习生
  status       String   // open, paused, closed
  description  String   @db.Text  // 富文本
  requirements String   @db.Text  // 富文本
  hcRequestId  String?  // 关联的编制申请ID

  createdById  String
  createdBy    User     @relation("CreatedJobs", fields: [createdById], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系：一个 Job 有多个 Candidate（通过关联表）
  candidateJobs CandidateJob[]

  // 关系：一个 Job 有多个标签（通过关联表）
  jobTags JobTag[]

  // 关系：一个 Job 有多个面试安排
  interviews Interview[]

  @@index([title])
  @@index([status])
  @@index([type])
  @@index([location])
  @@index([createdById])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([location, createdAt])
  @@map("job")
}

// ==================== 候选人表 ====================
model Candidate {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String
  gender          String
  age             Int?
  education       String
  school          String?
  workYears       Int?     // 工作年限
  currentCompany  String?
  currentPosition String?
  expectedSalary  String?
  resumeUrl       String?
  source          String   // 渠道
  sourceNote      String?
  referrer        String?  // 推荐人（内部推荐时使用）
  intro           String?  @db.Text  // 候选人说明
  skills          Json? // 技能标签（从简历解析或手动维护）
  
  createdById     String
  createdBy       User     @relation("CreatedCandidates", fields: [createdById], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系：一个 Candidate 关联多个 Job（通过关联表）
  candidateJobs CandidateJob[]

  // 关系：一个 Candidate 有多个标签（通过关联表）
  candidateTags CandidateTag[]

  // 关系：一个 Candidate 有多个 StageRecord
  stageRecords  StageRecord[]
  
  // 关系：一个 Candidate 有多个 InterviewFeedback
  interviewFeedbacks InterviewFeedback[]

  // 关系：一个 Candidate 有多个 Interview（面试安排）
  interviews Interview[]

  // 关系：一个 Candidate 有一个 Offer
  offer Offer?

  // 关系：一个 Candidate 有多个工作经历
  workHistories WorkHistory[]

  // 关系：一个 Candidate 收到多封邮件
  emailLogs EmailLog[]

  // 关系：一个 Candidate 有多个沟通记录
  communicationLogs CommunicationLog[]

  // 关系：一个 Candidate 有多个入职任务
  onboardingTasks OnboardingTask[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([source])
  @@index([createdById])
  @@index([createdAt])
  @@index([source, createdAt])
  @@index([education, createdAt])
  @@map("candidate")
}

// ==================== 候选人与职位关联表（多对多） ====================
model CandidateJob {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@map("candidate_job")
}

// ==================== 工作经历表 ====================
model WorkHistory {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  company     String    // 公司名称
  position    String    // 职位名称
  startDate   DateTime? // 开始时间
  endDate     DateTime? // 结束时间（null 表示至今）
  description String?   @db.Text // 工作描述/职责

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([candidateId])
  @@map("work_history")
}

// ==================== 流程阶段记录表 ====================
model StageRecord {
  id           String    @id @default(cuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  stage        String    // 入库, 初筛, 复试, 终面, 拟录用, Offer, 入职
  status       String    // in_progress, passed, rejected
  rejectReason String?
  
  assigneeId   String?
  assignee     User?     @relation("AssignedStages", fields: [assigneeId], references: [id])
  
  enteredAt    DateTime  @default(now())  // 进入时间
  completedAt  DateTime? // 完成时间
  note         String?   @db.Text  // 阶段备注
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId, enteredAt])
  @@index([stage])
  @@index([status])
  @@index([assigneeId])
  @@index([enteredAt])
  @@index([createdAt])
  @@index([stage, enteredAt])
  @@index([status, enteredAt])
  @@index([candidateId, stage, enteredAt])
  @@map("stage_record")
}

// ==================== 面试反馈记录表 ====================
model InterviewFeedback {
  id               String    @id @default(cuid())
  candidateId      String
  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  round            String    // 初试, 复试, 终面
  interviewerName  String
  interviewTime    DateTime
  conclusion       String    // pass, reject, pending
  feedbackContent  String    @db.Text  // 富文本
  rejectReason     String?
  
  createdById      String
  createdBy        User      @relation("CreatedFeedbacks", fields: [createdById], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId])
  @@index([round])
  @@index([conclusion])
  @@index([interviewTime])
  @@index([createdById])
  @@index([createdAt])
  @@map("interview_feedback")
}

// ==================== 面试安排表 ====================
model Interview {
  id            String    @id @default(cuid())
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId         String?
  job           Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)

  round         String    // 初试, 复试, 终面
  type          String    // 电话, 视频, 现场
  interviewers  Json      // JSON 数组 [{id, name}]
  scheduledAt   DateTime  // 计划面试时间
  duration      Int       @default(60) // 面试时长（分钟）
  location      String?   // 面试地点或会议链接
  notes         String?   @db.Text // 面试备注/准备事项
  status        String    @default("scheduled") // scheduled, completed, cancelled, no_show

  createdById   String
  createdBy     User      @relation("CreatedInterviews", fields: [createdById], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([candidateId])
  @@index([jobId])
  @@index([scheduledAt])
  @@index([status])
  @@index([createdById])
  @@index([scheduledAt, status])
  @@map("interview")
}

// ==================== Offer记录表 ====================
model Offer {
  id               String    @id @default(cuid())
  candidateId      String    @unique  // 一个 Candidate 只有一个 Offer
  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  salary           String
  offerDate        DateTime
  expectedJoinDate DateTime?
  result           String    // pending, accepted, rejected
  joined           Boolean   @default(false)  // 是/否
  actualJoinDate   DateTime?
  note             String?   @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId])
  @@index([result])
  @@index([joined])
  @@index([offerDate])
  @@index([createdAt])
  @@map("offer")
}

// ==================== 操作日志表 ====================
model OperationLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("UserOperationLogs", fields: [userId], references: [id])
  
  targetType String   // Job, Candidate, StageRecord, Offer 等
  targetId   String
  action     String   // created, updated, deleted, status_changed 等
  detail     Json     // 操作详情
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([targetType])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
  @@map("operation_log")
}

// ==================== 标签表 ====================
model Tag {
  id        String   @id @default(cuid())
  name      String   // 标签名
  color     String   @default("#409EFF") // 标签颜色
  category  String   @default("custom") // 系统预设 / 自定义
  createdById String?
  createdAt DateTime @default(now())

  candidateTags CandidateTag[]
  jobTags       JobTag[]

  @@unique([name])
  @@index([category])
  @@map("tag")
}

// ==================== 候选人与标签关联表 ====================
model CandidateTag {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([candidateId, tagId])
  @@index([candidateId])
  @@index([tagId])
  @@map("candidate_tag")
}

// ==================== 职位与标签关联表 ====================
model JobTag {
  id          String    @id @default(cuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([jobId, tagId])
  @@index([jobId])
  @@index([tagId])
  @@map("job_tag")
}

// ==================== 入职任务清单表 ====================
model OnboardingTask {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  title       String   // 任务名称：收集身份证复印件、邮箱开通、工位安排...
  category    String   // 材料收集 / IT准备 / 行政安排 / 培训
  assigneeId  String?  // 负责人（HR/IT/行政）
  status      String   @default("pending") // pending/in_progress/completed
  dueDate     DateTime? // 截止日期
  note        String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([candidateId])
  @@index([status])
  @@index([category])
  @@map("onboarding_task")
}

// ==================== 字典表（系统配置） ====================
model Dictionary {
  id          String   @id @default(cuid())
  category    String   // 字典分类：department, location 等
  code        String   // 内部编码
  name        String   // 显示名称
  sortOrder   Int      @default(0) // 排序权重
  enabled     Boolean  @default(true)
  description String?  // 备注说明
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([category, enabled])
  @@index([category, sortOrder])
  @@map("dictionary")
}

// ==================== 邮件模板表 ====================
model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   // 模板名称，如：面试邀请、Offer通知
  subject   String   // 邮件主题（支持 {{变量}}）
  body      String   @db.Text // 邮件正文（支持 {{变量}}）
  variables Json     // 预设变量列表，如 ["candidateName", "jobTitle", "interviewTime"]
  createdById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailLogs       EmailLog[]        @relation("TemplateEmailLogs")
  automationRules AutomationRule[]

  @@index([name])
  @@index([createdById])
  @@map("email_template")
}

// ==================== 邮件发送日志表 ====================
model EmailLog {
  id           String   @id @default(cuid())
  templateId   String?
  template     EmailTemplate? @relation("TemplateEmailLogs", fields: [templateId], references: [id])
  candidateId  String?
  candidate    Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  toEmail      String   // 收件人邮箱
  subject      String   // 实际发送的主题
  body         String   @db.Text // 实际发送的正文
  status       String   // sent, failed
  errorMessage String?
  sentAt       DateTime @default(now())
  createdById  String

  @@index([templateId])
  @@index([candidateId])
  @@index([toEmail])
  @@index([status])
  @@index([sentAt])
  @@map("email_log")
}

// ==================== 自动化邮件规则表 ====================
model AutomationRule {
  id            String        @id @default(cuid())
  triggerStage  String        // 初筛 | Offer | 入职
  triggerStatus String        // passed
  templateId    String
  template      EmailTemplate @relation(fields: [templateId], references: [id])
  enabled       Boolean       @default(true)
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([triggerStage, triggerStatus])
  @@index([enabled])
  @@map("automation_rule")
}

// ==================== 候选人沟通记录表 ====================
model CommunicationLog {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  type        String   // 电话, 邮件, 微信, 短信, 面谈
  content     String   @db.Text // 沟通内容摘要
  result      String?  // 沟通结果
  followUpAt  DateTime? // 下次跟进提醒时间

  createdById String
  createdBy   User     @relation("CreatedCommunicationLogs", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId])
  @@index([candidateId, createdAt])
  @@index([type])
  @@index([followUpAt])
  @@map("communication_log")
}

// ==================== 系统通知表 ====================
model Notification {
  id           String   @id @default(cuid())
  recipientId  String
  recipient    User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  title        String   // 通知标题
  content      String   @db.Text // 通知内容
  type         String   // stage_advance | interview_scheduled | offer_status | onboarding_reminder
  businessId   String?  // 关联业务ID
  businessType String?  // candidate | interview | offer
  isRead       Boolean  @default(false)
  readAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
  @@map("notification")
}

// ==================== HC编制申请表 ====================
model HCRequest {
  id           String    @id @default(cuid())
  title        String    // 岗位名称
  department   String    // 需求部门
  level        String    // 职级（P6, M2 等）
  headcount    Int       // 需求人数
  filledCount  Int       @default(0) // 已招人数
  urgency      String    // urgent | normal | low
  expectedDate DateTime? // 期望到岗时间
  salaryMin    String?   // 薪资下限
  salaryMax    String?   // 薪资上限
  reason       String    // new | replacement | expansion
  reasonNote   String?   @db.Text // 需求说明
  status       String    @default("draft") // draft | submitted | approved | rejected | fulfilled
  submittedAt  DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?

  // 申请人
  requesterId  String
  requester    User      @relation("HCRequests", fields: [requesterId], references: [id])

  // 审批人
  approverId   String?
  approver     User?     @relation("HCApprovals", fields: [approverId], references: [id])
  approveNote  String?   // 审批意见

  // 关联职位
  createdJobId String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([requesterId])
  @@index([department])
  @@index([createdAt])
  @@map("hc_request")
}
