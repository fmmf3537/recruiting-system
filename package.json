{
  "name": "recruitment-system",
  "version": "1.0.0",
  "description": "招聘管理系统 - 全栈项目",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "cd client && pnpm dev",
    "dev:server": "cd server && pnpm dev",
    "dev:mobile": "cd mobile && pnpm dev",
    "build": "pnpm build:server && pnpm build:client && pnpm build:mobile",
    "build:client": "cd client && pnpm build",
    "build:server": "cd server && pnpm build",
    "build:mobile": "cd mobile && pnpm build",
    "lint": "pnpm lint:client && pnpm lint:server && pnpm lint:mobile",
    "lint:client": "cd client && pnpm lint",
    "lint:server": "cd server && pnpm lint",
    "lint:mobile": "cd mobile && pnpm lint",
    "format": "pnpm format:client && pnpm format:server && pnpm format:mobile",
    "format:client": "cd client && pnpm format",
    "format:server": "cd server && pnpm format",
    "format:mobile": "cd mobile && pnpm format"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  }
}
